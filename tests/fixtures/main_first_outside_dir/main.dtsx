<?xml version="1.0" encoding="utf-8"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
                DTS:ExecutableType="Microsoft.Package"
                DTS:ObjectName="OutsideMain">
  <DTS:Executables>
    <DTS:Executable DTS:ExecutableType="Microsoft.ExecutePackageTask"
                    DTS:refId="EPT_OUTSIDE"
                    DTS:ObjectName="Run Sibling One Level Up">
      <DTS:ObjectData>
        <ExecutePackageTask>
          <PackageName>../sibling.dtsx</PackageName>
          <PackagePath>../sibling.dtsx</PackagePath>
        </ExecutePackageTask>
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
</DTS:Executable>
