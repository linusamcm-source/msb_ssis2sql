<?xml version="1.0" encoding="utf-8"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
                DTS:ExecutableType="Microsoft.Package"
                DTS:ObjectName="aggregate_group"
                DTS:VersionBuild="1">
  <DTS:ConnectionManagers>
    <DTS:ConnectionManager DTS:refId="Package.ConnectionManagers[ODBC]"
                           DTS:ObjectName="ODBC"
                           DTS:CreationName="OLEDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager
            DTS:ConnectionString="Data Source=localhost;Initial Catalog=val_aggregate_group;Provider=SQLNCLI11;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <DTS:Executables>
    <DTS:Executable DTS:ExecutableType="Microsoft.Pipeline"
                    DTS:ObjectName="DFT Aggregate"
                    DTS:refId="Package\DFT Aggregate">
      <DTS:ObjectData>
        <pipeline>
          <components>

            <component refId="Src" name="Source"
                       componentClassID="Microsoft.ODBCSource">
              <properties>
                <property name="AccessMode">2</property>
                <property name="SqlCommand">SELECT id, region, amount, qty FROM dbo.src_sales</property>
              </properties>
              <connections>
                <connection refId="Src.Connection"
                            connectionManagerID="Package.ConnectionManagers[ODBC]"
                            connectionManagerRefId="Package.ConnectionManagers[ODBC]"
                            name="OleDbConnection" />
              </connections>
              <outputs>
                <output refId="Src.Output" name="OLE DB Source Output">
                  <outputColumns>
                    <outputColumn refId="Src.Output.id" name="id" dataType="i4" />
                    <outputColumn refId="Src.Output.region" name="region" dataType="wstr" length="50" />
                    <outputColumn refId="Src.Output.amount" name="amount" dataType="numeric" precision="18" scale="4" />
                    <outputColumn refId="Src.Output.qty" name="qty" dataType="i4" />
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Aggregate: GROUP BY region, SUM/AVG/MIN/MAX/COUNT/COUNT DISTINCT -->
            <component refId="Agg" name="Aggregate by Region"
                       componentClassID="Microsoft.Aggregate">
              <inputs>
                <input refId="Agg.Input" name="Aggregate Input">
                  <inputColumns>
                    <inputColumn refId="Agg.Input.region" cachedName="region"
                                 lineageId="Src.Output.region" usageType="readOnly">
                      <properties>
                        <property name="AggregationType">GroupBy</property>
                      </properties>
                    </inputColumn>
                    <inputColumn refId="Agg.Input.amount" cachedName="amount"
                                 lineageId="Src.Output.amount" usageType="readOnly">
                      <properties>
                        <property name="AggregationType">Sum</property>
                      </properties>
                    </inputColumn>
                    <inputColumn refId="Agg.Input.qty" cachedName="qty"
                                 lineageId="Src.Output.qty" usageType="readOnly">
                      <properties>
                        <property name="AggregationType">Count</property>
                      </properties>
                    </inputColumn>
                  </inputColumns>
                </input>
              </inputs>
              <outputs>
                <output refId="Agg.Output" name="Aggregate Output">
                  <outputColumns>
                    <outputColumn refId="Agg.Output.region" name="region" dataType="wstr" length="50">
                      <properties>
                        <property name="AggregationType">GroupBy</property>
                        <property name="AggregationColumnId">Src.Output.region</property>
                      </properties>
                    </outputColumn>
                    <outputColumn refId="Agg.Output.total_amount" name="total_amount"
                                  dataType="numeric" precision="18" scale="4">
                      <properties>
                        <property name="AggregationType">Sum</property>
                        <property name="AggregationColumnId">Src.Output.amount</property>
                      </properties>
                    </outputColumn>
                    <outputColumn refId="Agg.Output.avg_amount" name="avg_amount"
                                  dataType="numeric" precision="18" scale="4">
                      <properties>
                        <property name="AggregationType">Average</property>
                        <property name="AggregationColumnId">Src.Output.amount</property>
                      </properties>
                    </outputColumn>
                    <outputColumn refId="Agg.Output.min_amount" name="min_amount"
                                  dataType="numeric" precision="18" scale="4">
                      <properties>
                        <property name="AggregationType">Minimum</property>
                        <property name="AggregationColumnId">Src.Output.amount</property>
                      </properties>
                    </outputColumn>
                    <outputColumn refId="Agg.Output.max_amount" name="max_amount"
                                  dataType="numeric" precision="18" scale="4">
                      <properties>
                        <property name="AggregationType">Maximum</property>
                        <property name="AggregationColumnId">Src.Output.amount</property>
                      </properties>
                    </outputColumn>
                    <outputColumn refId="Agg.Output.row_count" name="row_count" dataType="i8">
                      <properties>
                        <property name="AggregationType">CountAll</property>
                      </properties>
                    </outputColumn>
                    <outputColumn refId="Agg.Output.distinct_ids" name="distinct_ids" dataType="i8">
                      <properties>
                        <property name="AggregationType">CountDistinct</property>
                        <property name="AggregationColumnId">Src.Output.id</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Sort by region ascending — feeds destination directly for ORDER BY -->
            <component refId="Srt" name="Sort by Region"
                       componentClassID="Microsoft.Sort">
              <properties>
                <property name="EliminateDuplicates">false</property>
              </properties>
              <inputs>
                <input refId="Srt.Input" name="Sort Input">
                  <inputColumns>
                    <inputColumn refId="Srt.Input.region" cachedName="region"
                                 lineageId="Agg.Output.region" usageType="readWrite">
                      <properties>
                        <property name="NewSortKeyPosition">1</property>
                      </properties>
                    </inputColumn>
                  </inputColumns>
                </input>
              </inputs>
              <outputs>
                <output refId="Srt.Output" name="Sort Output" />
              </outputs>
            </component>

            <component refId="Dst" name="Destination"
                       componentClassID="Microsoft.ODBCDestination">
              <properties>
                <property name="AccessMode">0</property>
                <property name="OpenRowset">[dbo].[dst_region_totals]</property>
              </properties>
              <connections>
                <connection refId="Dst.Connection"
                            connectionManagerID="Package.ConnectionManagers[ODBC]"
                            connectionManagerRefId="Package.ConnectionManagers[ODBC]"
                            name="OleDbConnection" />
              </connections>
              <inputs>
                <input refId="Dst.Input" name="OLE DB Destination Input">
                  <inputColumns>
                    <inputColumn refId="Dst.Input.region" cachedName="region" usageType="readOnly" />
                    <inputColumn refId="Dst.Input.total_amount" cachedName="total_amount" usageType="readOnly" />
                    <inputColumn refId="Dst.Input.avg_amount" cachedName="avg_amount" usageType="readOnly" />
                    <inputColumn refId="Dst.Input.min_amount" cachedName="min_amount" usageType="readOnly" />
                    <inputColumn refId="Dst.Input.max_amount" cachedName="max_amount" usageType="readOnly" />
                    <inputColumn refId="Dst.Input.row_count" cachedName="row_count" usageType="readOnly" />
                    <inputColumn refId="Dst.Input.distinct_ids" cachedName="distinct_ids" usageType="readOnly" />
                  </inputColumns>
                </input>
              </inputs>
            </component>

          </components>
          <paths>
            <path refId="p1" startId="Src.Output" endId="Agg.Input" />
            <path refId="p2" startId="Agg.Output" endId="Srt.Input" />
            <path refId="p3" startId="Srt.Output" endId="Dst.Input" />
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
</DTS:Executable>
