# ---------------------------------------------------------------------------
# MSSQL connection parameters for the validation framework.
#
# Copy this file to .env (gitignored) and fill in the values for your
# operator-provisioned SQL Server instance. The real .env is never committed.
#
# Authentication is Windows-only (Trusted_Connection=yes). The agent and
# validation pipelines run as the local Windows user — make sure that
# Windows account has the required SQL Server logins/roles. No SA username
# or password is needed; do not add MSSQL_SA_USERNAME or MSSQL_SA_PASSWORD
# back to this file.
# ---------------------------------------------------------------------------

MSSQL_SERVER_ADDRESS=your-sql-server-host-or-ip
MSSQL_SERVER_PORT=1433
